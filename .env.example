# Copy to .env and fill in. DATABASE_URL and AUTH_SECRET are enough for local dev.

DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas"

# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"

# Used to create rotating one-way visitor hashes for unique analytics.
# Generate independently in production with: openssl rand -base64 32
ANALYTICS_SALT="change-me-too"

# Public base URL of the app (metadata/OG + auth callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Public DNS target shown when users connect custom domains.
# In production, set this to the hostname serving Atlas (for example atlas.example.com).
CUSTOM_DOMAIN_CNAME="localhost"

# Recommended production authentication and media storage. The publishable key
# is safe for the browser; the service role key must remain server-only.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_MEDIA_BUCKET="atlas-media"
# Enable only after GitHub is configured in Supabase Auth providers.
SUPABASE_AUTH_GITHUB_ENABLED="false"

# Legacy GitHub OAuth fallback. In development, Atlas provides a local email
# login when Supabase and these values are empty.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Optional lead email notifications. SMTP_USER/PASS may stay empty for a local relay.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Atlas <notifications@example.com>"

# Optional signed webhook for every new lead. HTTPS is required in production.
LEAD_WEBHOOK_URL=""
LEAD_WEBHOOK_SECRET=""

# Protects POST /api/jobs/notifications. Invoke it periodically (for example,
# every five minutes) to retry failed email and webhook notifications.
CRON_SECRET=""
